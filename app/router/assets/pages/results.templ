package pages

import (
	"github.com/ninesl/vinyl-keeper/app/router/assets/ui/parts"
	"github.com/ninesl/vinyl-keeper/app/vinyl"
)

templ ScanResultCard(v vinyl.VinylUnique, similarity float64) {
	@parts.ConfidenceBadgeWrapper(similarity) {
		@parts.VinylCard(parts.NewAlbumVinylRender(v))
	}
}

templ LowConfidenceChoiceCards(vinyls []vinyl.VinylUnique, similarities []float64) {
	@parts.LowConfidenceChoiceCards(vinyls, similarities)
}
