package pages

import (
	"github.com/ninesl/vinyl-keeper/app/router/assets/ui/parts"
	"github.com/ninesl/vinyl-keeper/app/router/types"
)

templ ScanResultCard(v types.Vinyl, similarity float64) {
	@parts.ConfidenceBadgeWrapper(similarity) {
		@parts.VinylCard(parts.NewAlbumVinylRender(v))
	}
}

templ LowConfidenceChoiceCards(vinyls []types.Vinyl, similarities []float64) {
	@parts.LowConfidenceChoiceCards(vinyls, similarities)
}
